{
  "name": "saucedemo-playwright-tests",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright test framework for SauceDemo application",
  "main": "index.js",
  "type": "module",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:chrome": "playwright test --project=chrome",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:sanity": "playwright test --grep @sanity",
    "test:serial": "playwright test --workers=1",
    "test:failfast": "playwright test --max-failures=1",
    "test:report": "playwright show-report",
    "test:trace": "playwright show-trace",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clean": "rm -rf allure-results allure-report",
    "lint": "eslint tests/**/*.js",
    "lint:fix": "eslint tests/**/*.js --fix",
    "format": "prettier --write tests/**/*.js",
    "ci": "CI=true playwright test",
    "ci:report": "CI=true playwright test && npm run allure:report"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "saucedemo",
    "automation"
  ],
  "author": "QA Team",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^2.15.1",
    "dotenv": "^16.6.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
