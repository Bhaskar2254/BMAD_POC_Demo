# Playwright Test Environment Configuration

# Base URL for SauceDemo application
BASE_URL=https://www.saucedemo.com

# Test Credentials (standard demo users)
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce

# Optional: Start a local server during tests
# START_SERVER=true

# CI/CD Detection (set automatically by most CI platforms)
# CI=true

# Allure Report Directory
ALLURE_RESULTS_DIR=allure-results

# Test Timeouts (in milliseconds)
# ACTION_TIMEOUT=10000
# NAVIGATION_TIMEOUT=30000

# Parallel Workers (override default)
# WORKERS=4

# Debug Flags
# DEBUG=pw:api
# PWDEBUG=1
